+		__virtio_set_bit(vdev, VIRTIO_F_DMB);
+}
+
+/* DMB DMA mapping helpers — optimized with hash table + slab cache */
+struct vp_dmb_mapping {
+	struct hlist_node node;
+	dma_addr_t handle;
+	void *va;
+	size_t size;
+};
+
+static void *vp_dmb_dma_alloc(struct device *dev, size_t size,
+			       dma_addr_t *dma_handle, gfp_t gfp,
+			       unsigned long attrs)
+{
+	struct pci_dev *pci_dev = to_pci_dev(dev);
+	struct virtio_pci_device *vp_dev = pci_get_drvdata(pci_dev);
+	ulong addr;
+
+	if (!vp_dev || !vp_dev->dmb_pool)
+		return NULL;
+
+	size = ALIGN(size, SMP_CACHE_BYTES);
+	addr = gen_pool_alloc(vp_dev->dmb_pool, size);
+	if (!addr)
+		return NULL;
+
+	*dma_handle = addr - (ulong)vp_dev->dmb_mem;
+	return (void *)addr;
+}
+
+static void vp_dmb_dma_free(struct device *dev, size_t size, void *vaddr,
+			     dma_addr_t dma_handle, unsigned long attrs)
+{
+	struct pci_dev *pci_dev = to_pci_dev(dev);
+	struct virtio_pci_device *vp_dev = pci_get_drvdata(pci_dev);
+
+	if (vp_dev && vp_dev->dmb_pool && vaddr)
+		gen_pool_free(vp_dev->dmb_pool, (ulong)vaddr, size);
+}
+
+static dma_addr_t vp_dmb_dma_map_page(struct device *dev, struct page *page,
+				       unsigned long offset, size_t size,
+				       enum dma_data_direction dir,
+				       unsigned long attrs)
+{
+	struct pci_dev *pci_dev = to_pci_dev(dev);
+	struct virtio_pci_device *vp_dev = pci_get_drvdata(pci_dev);
+	dma_addr_t shmem_handle;
+	void *shmem_vaddr;
+	struct vp_dmb_mapping *mapping;
+
+	shmem_vaddr = vp_dmb_dma_alloc(dev, size, &shmem_handle, GFP_ATOMIC, 0);
+	if (!shmem_vaddr)
+		return DMA_MAPPING_ERROR;
+
+	mapping = kmem_cache_alloc(vp_dev->dmb_map_cache, GFP_ATOMIC);
+	if (!mapping) {
+		vp_dmb_dma_free(dev, size, shmem_vaddr, shmem_handle, 0);
+		return DMA_MAPPING_ERROR;
+	}
+
+	mapping->handle = shmem_handle;
+	mapping->va = page_address(page) + offset;
+	mapping->size = size;
+
+	if (!(attrs & DMA_ATTR_SKIP_CPU_SYNC) &&
+	    (dir == DMA_TO_DEVICE || dir == DMA_BIDIRECTIONAL))
+		memcpy(shmem_vaddr, mapping->va, size);
+
+	spin_lock(&vp_dev->dmb_lock);
+	hash_add(vp_dev->dmb_map_ht, &mapping->node, (u32)shmem_handle);
+	spin_unlock(&vp_dev->dmb_lock);
+
+	return shmem_handle;
+}
+
+static void vp_dmb_dma_unmap_page(struct device *dev, dma_addr_t map_handle,
+				   size_t size, enum dma_data_direction dir,
+				   unsigned long attrs)
+{
+	struct pci_dev *pci_dev = to_pci_dev(dev);
+	struct virtio_pci_device *vp_dev = pci_get_drvdata(pci_dev);
+	void *shmem_vaddr = vp_dev->dmb_mem + map_handle;
+	struct vp_dmb_mapping *mapping;
+	bool found = false;
+
+	spin_lock(&vp_dev->dmb_lock);
+	hash_for_each_possible(vp_dev->dmb_map_ht, mapping, node,
+			       (u32)map_handle) {
+		if (mapping->handle == map_handle) {
+			hash_del(&mapping->node);
+			found = true;
+			break;
+		}
+	}
+	spin_unlock(&vp_dev->dmb_lock);
+
+	if (!found) {
+		dev_warn(dev, "DMB unmap without map for handle %llx\n",
+			 (unsigned long long)map_handle);
+		return;
+	}
+
+	if (!(attrs & DMA_ATTR_SKIP_CPU_SYNC) &&
+	    (dir == DMA_FROM_DEVICE || dir == DMA_BIDIRECTIONAL))
+		memcpy(mapping->va, shmem_vaddr, size);
+
+	kmem_cache_free(vp_dev->dmb_map_cache, mapping);
+	vp_dmb_dma_free(dev, size, shmem_vaddr, map_handle, 0);
+}
+
+static void vp_dmb_dma_sync_single_for_cpu(struct device *dev,
+					    dma_addr_t map_handle,
+					    size_t size,
+					    enum dma_data_direction dir)
+{
+	struct pci_dev *pci_dev = to_pci_dev(dev);
+	struct virtio_pci_device *vp_dev = pci_get_drvdata(pci_dev);
+	void *shmem_vaddr = vp_dev->dmb_mem + map_handle;
+	struct vp_dmb_mapping *mapping;
+	bool found = false;
+
+	spin_lock(&vp_dev->dmb_lock);
+	hash_for_each_possible(vp_dev->dmb_map_ht, mapping, node,
+			       (u32)map_handle) {
+		if (mapping->handle == map_handle) {
+			found = true;
+			break;
+		}
+	}
+	spin_unlock(&vp_dev->dmb_lock);
+
+	if (!found) {
+		dev_warn_once(dev, "DMB sync_for_cpu without map for handle %llx\n",
+			      (unsigned long long)map_handle);
+		return;
+	}
+
+	if (dir == DMA_FROM_DEVICE || dir == DMA_BIDIRECTIONAL)
+		memcpy(mapping->va, shmem_vaddr, size);
+}
+
+static void vp_dmb_dma_sync_single_for_device(struct device *dev,
+					       dma_addr_t map_handle,
+					       size_t size,
+					       enum dma_data_direction dir)
+{
+	struct pci_dev *pci_dev = to_pci_dev(dev);
+	struct virtio_pci_device *vp_dev = pci_get_drvdata(pci_dev);
+	void *shmem_vaddr = vp_dev->dmb_mem + map_handle;
+	struct vp_dmb_mapping *mapping;
+	bool found = false;
+
+	spin_lock(&vp_dev->dmb_lock);
+	hash_for_each_possible(vp_dev->dmb_map_ht, mapping, node,
+			       (u32)map_handle) {
+		if (mapping->handle == map_handle) {
+			found = true;
+			break;
+		}
+	}
+	spin_unlock(&vp_dev->dmb_lock);
+
+	if (!found) {
+		dev_warn_once(dev, "DMB sync_for_device without map for handle %llx\n",
+			      (unsigned long long)map_handle);
+		return;
+	}
+
+	if (dir == DMA_TO_DEVICE || dir == DMA_BIDIRECTIONAL)
+		memcpy(shmem_vaddr, mapping->va, size);
+}
+
+static size_t vp_dmb_dma_max_mapping_size(struct device *dev)
+{
+	struct pci_dev *pci_dev = to_pci_dev(dev);
+	struct virtio_pci_device *vp_dev = pci_get_drvdata(pci_dev);
+
+	if (vp_dev && vp_dev->dmb_pool) {
+		size_t pool = gen_pool_size(vp_dev->dmb_pool);
+		return min_t(size_t, pool / 8, 1024 * 1024);
+	}
+	return 1024 * 1024;
+}
+
+static const struct dma_map_ops vp_dmb_dma_ops = {
+	.alloc = vp_dmb_dma_alloc,
+	.free = vp_dmb_dma_free,
+	.map_page = vp_dmb_dma_map_page,
+	.unmap_page = vp_dmb_dma_unmap_page,
+	.sync_single_for_cpu = vp_dmb_dma_sync_single_for_cpu,
+	.sync_single_for_device = vp_dmb_dma_sync_single_for_device,
+	.max_mapping_size = vp_dmb_dma_max_mapping_size,
+};
+
+static void vp_dmb_free_reserved(void *data)
+{
+	struct virtio_pci_device *vp_dev = data;
+
+	if (vp_dev->dmb_pool && vp_dev->dmb_reserved)
+		gen_pool_free(vp_dev->dmb_pool, vp_dev->dmb_reserved,
+			      SMP_CACHE_BYTES);
 }
 
 /* virtio config->finalize_features() implementation */
@@ -57,6 +263,55 @@ static int vp_finalize_features(struct virtio_device *vdev)
 		return -EINVAL;
 	}
 
+	/* Initialize Device Memory Buffer if advertised by host */
+	if (__virtio_test_bit(vdev, VIRTIO_F_DMB)) {
+		struct virtio_shm_region region;
+
+		if (!virtio_get_shm_region(vdev, &region, VIRTIO_SHMEM_ID_DMB)) {
+			dev_warn(&vdev->dev, "Failed to find DMB region\n");
+			return -EINVAL;
+		}
+
+		vp_dev->dmb_pool = devm_gen_pool_create(&vdev->dev,
+					ilog2(SMP_CACHE_BYTES), -1, "virtio-dmb");
+		vp_dev->dmb_mem = devm_memremap(&vdev->dev, region.addr,
+					region.len, MEMREMAP_WB | MEMREMAP_DEC);
+		hash_init(vp_dev->dmb_map_ht);
+		spin_lock_init(&vp_dev->dmb_lock);
+		vp_dev->dmb_map_cache = kmem_cache_create("virtio-dmb-map",
+					sizeof(struct vp_dmb_mapping), 0,
+					SLAB_HWCACHE_ALIGN, NULL);
+		if (!vp_dev->dmb_map_cache) {
+			dev_warn(&vdev->dev, "Failed to create DMB slab cache\n");
+			return -ENOMEM;
+		}
+
+		if (vp_dev->dmb_pool) {
+			int ret = gen_pool_add_virt(vp_dev->dmb_pool,
+						(ulong)vp_dev->dmb_mem,
+						region.addr, region.len, -1);
+			if (ret != 0) {
+				dev_warn(&vdev->dev,
+					 "Failed to init DMB region\n");
+				return -EINVAL;
+			}
+
+			/* Reserve first cache line to avoid offset 0 allocs */
+			vp_dev->dmb_reserved =
+				gen_pool_alloc(vp_dev->dmb_pool, SMP_CACHE_BYTES);
+			devm_add_action(&vdev->dev, vp_dmb_free_reserved,
+					vp_dev);
+
+			/* Override DMA ops for this PCI device */
+			set_dma_ops(&vp_dev->pci_dev->dev, &vp_dmb_dma_ops);
+
+			dev_info(&vdev->dev,
+				 "Enabled %lld bytes Virtio DMB region for %s\n",
+				 (long long)region.len,
+				 dev_name(&vp_dev->pci_dev->dev));
+		}
+	}
+
 	vp_modern_set_features(&vp_dev->mdev, vdev->features);
 
 	return 0;
